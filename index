const NSETS = 23;

const POSVI={n:'danh từ',v:'động từ',adj:'tính từ',adv:'trạng từ',phrase:'cụm từ'};
const POSCLASS={n:'pos-n',v:'pos-v',adj:'pos-adj',adv:'pos-adv',phrase:'pos-phrase'};
function posPill(p){return `<span class="pos-pill ${POSCLASS[p]||'pos-phrase'}">${(p||'').toUpperCase()}</span>`;}
function setWords(n){return VOCAB.filter(v=>v.setNum===n);}
function firstVar(s){return s.split('/')[0].trim();}
function norm(s){return s.toLowerCase().replace(/\s+/g,' ').trim();}

// ===== AUDIO / FX =====
let _ac=null;function getAudioCtx(){try{if(!_ac)_ac=new (window.AudioContext||window.webkitAudioContext)();return _ac}catch(e){return null}}
function playDing(){try{const c=getAudioCtx();if(!c)return;const o=c.createOscillator(),g=c.createGain();o.connect(g);g.connect(c.destination);o.type='sine';o.frequency.value=880;g.gain.value=.12;o.start();o.frequency.exponentialRampToValueAtTime(1320,c.currentTime+.12);g.gain.exponentialRampToValueAtTime(.001,c.currentTime+.3);o.stop(c.currentTime+.3)}catch(e){}}
function playBuzz(){try{const c=getAudioCtx();if(!c)return;const o=c.createOscillator(),g=c.createGain();o.connect(g);g.connect(c.destination);o.type='sawtooth';o.frequency.value=150;g.gain.value=.15;o.start();g.gain.exponentialRampToValueAtTime(.001,c.currentTime+.3);o.stop(c.currentTime+.3)}catch(e){}}
function speakById(id){const v=VOCAB.find(x=>x.id===id);if(!v)return;speakWord(firstVar(v.en));}
function speakWord(w){try{if(!window.speechSynthesis)return;const u=new SpeechSynthesisUtterance(w);u.lang='en-US';u.rate=.85;speechSynthesis.speak(u)}catch(e){}}
function showConfetti(big=false){const c=document.createElement('div');c.className='confetti';document.body.appendChild(c);const count=big?70:30;const colors=['#FFAFCC','#457B9D','#A8DADC','#FFD700','#FF6B6B','#9b5de5','#00bbf9'];for(let i=0;i<count;i++){const p=document.createElement('div');const size=4+Math.random()*8;const shape=Math.random()>.5?'50%':'2px';const dur=(1.2+Math.random()*1.8).toFixed(2);const rot=Math.floor(Math.random()*720-360);p.style.cssText=`position:fixed;width:${size}px;height:${size}px;background:${colors[Math.floor(Math.random()*colors.length)]};border-radius:${shape};left:${Math.random()*100}%;top:-10px;z-index:9999;--rot:${rot}deg;animation:confettiFall ${dur}s cubic-bezier(.25,.46,.45,.94) forwards`;c.appendChild(p)}if(!document.getElementById('cfk')){const s=document.createElement('style');s.id='cfk';s.textContent='@keyframes confettiFall{to{top:100%;opacity:0;transform:translateX(calc((var(--rot,180)/360)*60px)) rotate(var(--rot,180deg))}}';document.head.appendChild(s)}setTimeout(()=>c.remove(),3000)}
function showToast(msg,type='success'){document.querySelectorAll('.toast').forEach(t=>t.remove());const t=document.createElement('div');t.className='toast';t.style.background=type==='success'?'var(--success)':'var(--error)';t.textContent=msg;document.body.appendChild(t);setTimeout(()=>t.remove(),2500)}

// ===== STATE =====
let screen='home',selSet=1,mode=null,Q=[],qi=0,score=0,answered=false;
let progress={};VOCAB.forEach(()=>{});
for(let s=1;s<=NSETS;s++)progress[s]={m1:0,m2:0,m3:0,m4:0};
function shuffle(a){const b=[...a];for(let i=b.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[b[i],b[j]]=[b[j],b[i]]}return b}

function render(){const app=document.getElementById('app');if(!app)return;
  if(screen==='home')renderHome(app);
  else if(screen==='menu')renderMenu(app);
  else if(screen==='browse')renderBrowse(app);
  else if(screen==='game')renderGame(app);
  else if(screen==='result')renderResult(app);
  if(window.lucide)lucide.createIcons();}

