}

// ===== GAME GENERATION (scoped to selected set) =====
function pickWrongs(pool,correct,n){const others=shuffle(pool.filter(x=>x.id!==correct.id));return others.slice(0,n);}
function startMode(m){
  mode=m;qi=0;score=0;answered=false;
  const w=setWords(selSet);
  let pool=w.length>=4?w:VOCAB; // ensure enough distractors
  Q=[];
  if(m===1){ // VI -> EN mc
    shuffle(w).forEach(v=>{const opts=shuffle([v,...pickWrongs(pool,v,3)]);Q.push({type:'mc_en',v,opts});});
  }else if(m===2){ // EN -> VI mc
    shuffle(w).forEach(v=>{const opts=shuffle([v,...pickWrongs(pool,v,3)]);Q.push({type:'mc_vi',v,opts});});
  }else if(m===3){ // type EN from VI
    shuffle(w).forEach(v=>Q.push({type:'type',v}));
  }else if(m===4){ // word family
    const famWords=w.filter(v=>v.fam.length>=2);
    if(famWords.length===0){ // fallback to mc_en
      shuffle(w).forEach(v=>{const opts=shuffle([v,...pickWrongs(pool,v,3)]);Q.push({type:'mc_en',v,opts});});
    }else{
      shuffle(famWords).forEach(v=>{
        // choose a target family member with different surface form
        const targets=v.fam.filter(f=>firstVar(f.w).toLowerCase()!==firstVar(v.en).toLowerCase());
        const t=(targets.length?shuffle(targets):shuffle(v.fam))[0];
        Q.push({type:'family',v,target:t});
      });
    }
  }
  screen='game';render();
}

function renderGame(app){
  if(qi>=Q.length){const pct=Math.round(score/Q.length*100);progress[selSet]['m'+mode]=Math.max(progress[selSet]['m'+mode],pct);screen='result';render();return;}
  const q=Q[qi];
  const titles={1:'🔵 Việt → Anh',2:'🟢 Anh → Việt',3:'🟡 Điền từ',4:'🟣 Họ từ'};
  app.innerHTML=`
  <div class="min-h-full p-4 fade-in"><div class="max-w-lg mx-auto">
    <div class="flex items-center justify-between mb-3">
      <button onclick="screen='menu';render()" class="p-2 rounded-lg card-hover" style="background:#fff"><i data-lucide="arrow-left" style="width:20px;height:20px"></i></button>
      <span class="font-700 text-sm" style="color:var(--dark)">Bộ ${selSet} • ${titles[mode]}</span>
      <span class="text-sm font-600 px-3 py-1 rounded-full" style="background:#fff;color:var(--dark)">${qi+1}/${Q.length}</span>
    </div>
    <div class="progress-bar mb-5"><div class="progress-fill" style="width:${qi/Q.length*100}%"></div></div>
    <div class="text-center mb-2"><span id="scoreTag" class="tag" style="background:var(--pink);color:var(--dark)">Score: ${score}/${qi}</span></div>
    <div id="qArea" class="slide-in"></div>
    <div id="exArea" class="mt-4"></div>
    <div id="nextArea" class="mt-4 text-center"></div>
  </div></div>`;
  lucide.createIcons();renderQ(q);
}

function optBtns(opts,render_label,onclickName,correctId){
  return opts.map((o,i)=>`<button class="option-btn" onclick="${onclickName}(${correctId},${o.id},this)">${String.fromCharCode(65+i)}. ${render_label(o)}</button>`).join('');
}

function renderQ(q){
  const a=document.getElementById('qArea');
  if(q.type==='mc_en'){
    a.innerHTML=`
    <div class="rounded-2xl p-5 mb-4" style="background:#fff">
      <div class="flex items-center gap-2 mb-2">${posPill(q.v.pos)}<span class="tag" style="background:var(--bg)">${q.v.set}</span></div>
      <p class="text-xs opacity-60 mb-1">Chọn từ tiếng Anh đúng:</p>
      <p class="text-2xl font-800" style="color:var(--dark)">${q.v.vi}</p>
    </div>
    <div class="space-y-3">${optBtns(q.opts,o=>o.en,'checkMC',q.v.id)}</div>`;
  }else if(q.type==='mc_vi'){
    a.innerHTML=`
    <div class="rounded-2xl p-5 mb-4" style="background:#fff">
      <div class="flex items-center gap-2 mb-2">${posPill(q.v.pos)}
        <button onclick="speakById(${q.v.id})" class="p-1 rounded-full icon-spin" style="background:var(--pink)"><i data-lucide="volume-2" style="width:16px;height:16px"></i></button></div>
      <p class="text-xs opacity-60 mb-1">Chọn nghĩa tiếng Việt đúng:</p>
      <p class="text-2xl font-800" style="color:var(--dark)">${q.v.en}</p>
    </div>
    <div class="space-y-3">${optBtns(q.opts,o=>o.vi,'checkMC',q.v.id)}</div>`;
  }else if(q.type==='type'){
    const fw=firstVar(q.v.en);const hint=fw[0]+'·'.repeat(Math.max(0,fw.length-1));
    a.innerHTML=`
    <div class="rounded-2xl p-5 mb-4" style="background:#fff">
      <div class="flex items-center gap-2 mb-2">${posPill(q.v.pos)}<span class="tag" style="background:var(--bg)">${q.v.set}</span></div>
      <p class="text-xs opacity-60 mb-1">Gõ từ/cụm tiếng Anh có nghĩa:</p>
      <p class="text-2xl font-800 mb-2" style="color:var(--dark)">${q.v.vi}</p>
      <p class="text-sm" style="color:var(--accent)">💡 Gợi ý: <span class="font-700" style="letter-spacing:2px">${hint}</span> (${fw.length} ký tự)</p>
    </div>
    <div class="flex gap-2">
      <input id="ti" class="input-field flex-1" placeholder="Nhập tiếng Anh..." autocomplete="off" onkeydown="if(event.key==='Enter')checkType()">
      <button onclick="checkType()" class="btn-primary">Kiểm tra</button></div>`;
    setTimeout(()=>{const i=document.getElementById('ti');if(i)i.focus()},100);
  }else if(q.type==='family'){
    const tw=firstVar(q.target.w);const hint=tw[0]+'·'.repeat(Math.max(0,tw.length-1));
    a.innerHTML=`
    <div class="rounded-2xl p-5 mb-4" style="background:#fff">
      <div class="flex items-center gap-2 mb-2"><span class="tag master-glow" style="background:#FFD700;color:#000;font-weight:bold">👨‍👩‍👧 HỌ TỪ</span>${q.v.set}</div>
      <p class="text-sm opacity-70 mb-1">Từ gốc: <span class="font-800" style="color:var(--dark)">${q.v.en}</span> ${posPill(q.v.pos)}</p>
      <p class="text-sm opacity-60 mb-3">(${q.v.vi})</p>
      <div class="p-3 rounded-xl" style="background:#f3e8ff;border-left:4px solid #6f42c1">
        <p class="text-sm" style="color:#3e1f47">Hãy cho biết dạng <span class="font-800">${POSVI[q.target.pos]||'liên quan'} (${q.target.pos})</span> trong cùng họ từ:</p>
        <p class="text-xs opacity-70 mt-1" style="color:#3e1f47">Nghĩa cần tìm: <em>${q.target.vi}</em></p>
        <p class="text-sm mt-2" style="color:var(--accent)">💡 ${hint} (${tw.length} ký tự)</p>
      </div>
    </div>
    <div class="flex gap-2">
      <input id="ti" class="input-field flex-1" placeholder="Nhập dạng từ..." autocomplete="off" onkeydown="if(event.key==='Enter')checkFamily()">
      <button onclick="checkFamily()" class="btn-primary">Kiểm tra</button></div>`;
    setTimeout(()=>{const i=document.getElementById('ti');if(i)i.focus()},100);
  }
  lucide.createIcons();
}

function bump(){score++;const t=document.getElementById('scoreTag');if(t){t.textContent=`Score: ${score}/${qi}`;t.classList.remove('score-pop');void t.offsetWidth;t.classList.add('score-pop');}}

function checkMC(correctId,chosenId,btn){
  if(answered)return;answered=true;
  document.querySelectorAll('.option-btn').forEach(b=>b.style.pointerEvents='none');
  if(chosenId===correctId){btn.classList.add('correct');bump();playDing();showConfetti();showToast('✅ Chính xác!','success');}
  else{btn.classList.add('wrong');playBuzz();
    const cv=VOCAB.find(v=>v.id===correctId);
    document.querySelectorAll('.option-btn').forEach(b=>{if(b.textContent.includes(cv.en)||b.textContent.includes(cv.vi))b.classList.add('correct')});
    showToast('❌ Sai rồi!','error');}
  deepDive(Q[qi].v);nextBtn();
}
function matchAns(val,target){val=norm(val);const t=norm(firstVar(target));if(!val)return false;return val===t||(t.includes(val)&&val.length>=Math.min(4,t.length))||val===norm(target);}
function checkType(){
  if(answered)return;answered=true;const i=document.getElementById('ti');const q=Q[qi];
  const ok=matchAns(i.value,q.v.en);
  i.style.borderColor=ok?'var(--success)':'var(--error)';i.style.background=ok?'#d4edda':'#f8d7da';
  if(ok){bump();playDing();showConfetti();showToast('✅ Chính xác!','success');}else{playBuzz();showToast('Đáp án: '+q.v.en,'error');}
  deepDive(q.v);nextBtn();
}
function checkFamily(){
  if(answered)return;answered=true;const i=document.getElementById('ti');const q=Q[qi];
  const ok=matchAns(i.value,q.target.w);
  i.style.borderColor=ok?'var(--success)':'var(--error)';i.style.background=ok?'#d4edda':'#f8d7da';
  if(ok){bump();playDing();showConfetti();showToast('✅ Chính xác!','success');}else{playBuzz();showToast('Đáp án: '+q.target.w,'error');}
  deepDive(q.v);nextBtn();
}
function nextBtn(){document.getElementById('nextArea').innerHTML=`<button onclick="advance()" class="btn-primary text-lg px-8 next-btn-enter">Câu tiếp theo →</button>`;}
function advance(){const a=document.getElementById('qArea');if(a){a.style.transition='opacity .15s,transform .15s';a.style.opacity='0';a.style.transform='translateX(-20px)';}setTimeout(()=>{qi++;answered=false;renderGame(document.getElementById('app'))},150);}

// ===== DEEP DIVE (word family always shown) =====
function famHtml(v){return v.fam.map(f=>`<span class="fam-chip">${f.w}<span class="pos">${f.pos}</span></span>`).join('')
  +`<div class="mt-2 space-y-1">`+v.fam.map(f=>`<div class="text-sm"><span class="font-700">${f.w}</span> <span class="pos-pill ${POSCLASS[f.pos]}">${f.pos.toUpperCase()}</span> <span style="opacity:.7">— ${f.vi}</span></div>`).join('')+`</div>`;}
function pairList(arr,bg){return arr.map(p=>`<div class="text-sm"><span style="background:${bg};padding:2px 8px;border-radius:6px;font-weight:600">${p[0]}</span> <span style="opacity:.7">${p[1]}</span></div>`).join('');}
function deepDive(v){
  const hasEn=v.enDef&&v.enDef.length;
  document.getElementById('exArea').innerHTML=`
  <div class="rounded-2xl p-5 fade-in" style="background:#f0f8ff;border:2px solid #d0e8f0">
    <div class="flex items-center gap-2 mb-3">
      <span class="font-700 text-lg" style="color:var(--accent)">📖 Deep Dive</span>
      <button onclick="speakById(${v.id})" class="p-1 rounded-full icon-spin" style="background:var(--pink)"><i data-lucide="volume-2" style="width:14px;height:14px"></i></button>
    </div>
    <div class="p-4 rounded-xl mb-4" style="background:linear-gradient(135deg,#457B9D15,#FFAFCC15);border:1px solid var(--accent)">
      <p class="font-800 text-xl" style="color:var(--dark)">${v.en}</p>
      <p class="text-xs opacity-70 mt-1">${v.ipa?v.ipa+' ':''}${posPill(v.pos)}</p>
      <p class="font-600 mt-2" style="color:var(--accent)">🇻🇳 ${v.vi}</p>
      ${hasEn?`<p class="text-sm mt-1">🇬🇧 ${v.enDef}</p>`:''}
    </div>
    <div class="mb-4 p-3 rounded-lg" style="background:#fff;border:1px solid #6f42c1">
      <p class="text-sm font-700 mb-2" style="color:#3e1f47">👨‍👩‍👧 WORD FAMILY — Họ từ (Danh/Tính/Động/Trạng)</p>
      ${famHtml(v)}
    </div>
    ${v.collocations.length?`<div class="mb-4 p-3 rounded-lg" style="background:#fff;border:1px solid #ffc107"><p class="text-sm font-700 mb-2" style="color:#856404">🔗 COLLOCATIONS</p><div class="space-y-1">${pairList(v.collocations,'var(--bg)')}</div></div>`:''}
    ${v.synonyms.length?`<div class="mb-4 p-3 rounded-lg" style="background:#fff;border:1px solid #17a2b8"><p class="text-sm font-700 mb-2" style="color:#0c5460">↔️ SYNONYMS — Đồng nghĩa</p><div class="space-y-1">${pairList(v.synonyms,'#e2f4f8')}</div></div>`:''}
    ${v.antonyms.length?`<div class="mb-4 p-3 rounded-lg" style="background:#fff;border:1px solid #dc3545"><p class="text-sm font-700 mb-2" style="color:#721c24">⚖️ ANTONYMS — Trái nghĩa</p><div class="space-y-1">${pairList(v.antonyms,'#f8d7da')}</div></div>`:''}
    ${v.example?`<div class="p-4 rounded-lg" style="background:#fff3cd;border:2px solid #ffc107"><p class="text-sm font-700 mb-2" style="color:#856404">📝 EXAMPLE</p><p class="text-sm mb-2">${v.example}</p><p class="text-sm" style="color:var(--accent)">${v.exampleVi}</p></div>`:`<p class="text-xs opacity-50 italic">Định nghĩa/ví dụ chi tiết cho bộ này sẽ được bổ sung sau — phần họ từ &amp; nghĩa đã đầy đủ để học.</p>`}
  </div>`;
  lucide.createIcons();
}

// ===== RESULT =====
function renderResult(app){
  const total=Q.length,pct=Math.round(score/total*100);
  const emoji=pct>=80?'🏆':pct>=60?'👍':pct>=40?'💪':'📖';
  const msg=pct>=80?'Xuất sắc!':pct>=60?'Khá tốt!':pct>=40?'Cần ôn thêm!':'Cố lên nhé!';
  if(pct>=80)showConfetti(true);
  app.innerHTML=`
  <div class="flex flex-col items-center justify-center min-h-full p-6 fade-in">
    <div class="text-6xl mb-4 bounce-in">${emoji}</div>
    <h2 class="text-3xl font-800 mb-2" style="color:var(--dark)">${msg}</h2>
    <p class="text-lg mb-1 opacity-70">Bộ ${selSet} • Điểm: ${score}/${total} (${pct}%)</p>
    <div class="w-full max-w-xs my-5"><div class="progress-bar" style="height:12px"><div class="progress-fill" style="width:${pct}%"></div></div></div>
    <div class="space-y-3 w-full max-w-xs">
      <button onclick="startMode(${mode})" class="btn-primary w-full">🔄 Chơi lại</button>
      <button onclick="screen='menu';render()" class="btn-pink w-full">📦 Về menu Bộ ${selSet}</button>
      <button onclick="screen='home';render()" class="w-full py-3 rounded-xl font-600" style="background:var(--dark);color:#fff">🏠 Chọn bộ khác</button>
    </div>
  </div>`;
}

// ===== BROWSE (per set) =====
function renderBrowse(app){
  const w=setWords(selSet);
  app.innerHTML=`
  <div class="min-h-full p-4 fade-in"><div class="max-w-2xl mx-auto">
    <div class="flex items-center gap-3 mb-4">
      <button onclick="screen='menu';render()" class="p-2 rounded-lg" style="background:#fff"><i data-lucide="arrow-left" style="width:20px;height:20px"></i></button>
      <h2 class="text-xl font-700" style="color:var(--dark)">📘 Bộ ${selSet} — ${w.length} từ</h2>
    </div>
    <input id="bs" class="input-field mb-4" placeholder="🔍 Tìm trong bộ này..." oninput="filterBrowse(this.value)">
    <div id="bc">${browseCards(w)}</div>
  </div></div>`;
  lucide.createIcons();
}
function browseCards(list){
  return list.map((v,idx)=>`
  <div class="vocab-card card-hover fade-in" style="animation-delay:${Math.min(idx*0.03,0.5)}s">
    <div class="flex items-start justify-between mb-1">
      <div><span class="font-700 text-lg" style="color:var(--dark)">${v.en}</span>
        ${v.ipa?`<span class="ml-2 text-sm opacity-60">${v.ipa}</span>`:''} ${posPill(v.pos)}</div>
      <button onclick="speakById(${v.id})" class="p-1 rounded-full flex-shrink-0" style="background:var(--pink)"><i data-lucide="volume-2" style="width:16px;height:16px"></i></button>
    </div>
    <p class="font-600 mb-1" style="color:var(--accent)">${v.vi}</p>
    ${v.enDef?`<p class="text-sm opacity-70 mb-2">${v.enDef}</p>`:''}
    <div class="mt-1">${v.fam.map(f=>`<span class="fam-chip">${f.w}<span class="pos">${f.pos}</span></span>`).join('')}</div>
    ${(v.synonyms.length||v.example)?`<details class="mt-2"><summary class="text-sm font-600 cursor-pointer" style="color:var(--accent)">Xem chi tiết ▾</summary>
      <div class="mt-2 space-y-1 text-sm pl-2" style="border-left:2px solid var(--bg)">
        ${v.collocations.length?`<p><strong>Collocations:</strong> ${v.collocations.map(c=>c[0]).join(', ')}</p>`:''}
        ${v.synonyms.length?`<p><strong>Đồng nghĩa:</strong> ${v.synonyms.map(s=>s[0]).join(', ')}</p>`:''}
        ${v.antonyms.length?`<p><strong>Trái nghĩa:</strong> ${v.antonyms.map(a=>a[0]).join(', ')}</p>`:''}
        ${v.example?`<p class="mt-1 p-2 rounded-lg" style="background:#f8f9fa"><strong>Ví dụ:</strong> ${v.example}</p><p class="p-2 rounded-lg" style="background:#f0f8ff;color:var(--accent)">${v.exampleVi}</p>`:''}
      </div></details>`:''}
  </div>`).join('');
}
function filterBrowse(term){const t=term.toLowerCase();const w=setWords(selSet).filter(v=>v.en.toLowerCase().includes(t)||v.vi.toLowerCase().includes(t));document.getElementById('bc').innerHTML=browseCards(w);lucide.createIcons();}

render();
  </script>
 </body>
